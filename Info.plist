<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  DEVELOPMENT-ONLY ATS exception. The backend is currently reached over plain
	  HTTP at a public IP (http://45.195.159.233:3000). ATS domain exceptions do
	  not reliably match bare IP literals, so allowing arbitrary loads is the
	  minimal setting that works for HTTP-to-IP testing. localhost (Simulator) is
	  exempt regardless. All other Info.plist keys are still auto-generated by
	  GENERATE_INFOPLIST_FILE and merged with this file at build time.
	  TODO: once the backend has a domain + HTTPS, REMOVE this whole block.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<!-- HealthKit (Phase 3) — optional. Reading is opt-in; raw data stays on
	     device unless the user enables sync of daily aggregates. -->
	<key>NSHealthShareUsageDescription</key>
	<string>DeskFit can read your steps, workouts, sleep, and heart metrics to personalize and adapt your plan. This is optional — your data stays on your device unless you turn on sync.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>DeskFit can save your completed workouts to Apple Health. This is optional.</string>
</dict>
</plist>
