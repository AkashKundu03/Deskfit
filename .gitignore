# в”Ђв”Ђ macOS в”Ђв”Ђ
.DS_Store

# в”Ђв”Ђ Xcode: per-user state (should never be committed) в”Ђв”Ђ
xcuserdata/
*.xcuserstate
*.xcuserdatad

# в”Ђв”Ђ Xcode: build / derived data в”Ђв”Ђ
build/
DerivedData/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# в”Ђв”Ђ Swift Package Manager в”Ђв”Ђ
.build/
.swiftpm/

# в”Ђв”Ђ CocoaPods (if ever added) в”Ђв”Ђ
Pods/

# в”Ђв”Ђ Local secrets / config overrides (never commit) в”Ђв”Ђ
*.local.xcconfig
Secrets.xcconfig
